# AfterLife V2 — Stellar Soroban Configuration
# Copy this file to .env and fill in your values

# Deployed contract address (C... format)
VITE_CONTRACT_ID=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAABSC4

# Native XLM token contract on Stellar Testnet
VITE_NATIVE_TOKEN_ID=CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQVU2HHGCN3

# Platform treasury wallet (G... format)
VITE_PLATFORM_WALLET=GAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAWHF

# Soroban RPC (default: testnet)
VITE_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
